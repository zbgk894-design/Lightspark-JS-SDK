{
  "ignoreCommand": "git diff HEAD^ HEAD --quiet -- .",
  "installCommand": "npm install --ignore-scripts",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "ALLOWALL"
        },
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors *"
        }
      ]
    }
  ]
}
